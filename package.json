{
  "name": "novexa-workspace",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend",
    "frontend:lint": "npm run lint --workspace=frontend",
    "backend:dev": "npm run start --workspace=backend",
    "dev": "npm run frontend:dev",
    "start": "npm run backend:dev"
  }
}
